# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
TUNNEL_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# AI
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
BRUNO_ROUTER_MODEL=gpt-5.4-nano
BRUNO_STANDARD_MODEL=gpt-4o-mini
BRUNO_MEDIUM_MODEL=gpt-5.4-nano
BRUNO_DEEP_MODEL=gpt-5.4-mini
AI_LATENCY_DIAGNOSTICS=false
NEXT_PUBLIC_AI_LATENCY_DIAGNOSTICS=false

# Auth, cron, and encryption
CRON_SECRET=replace-with-random-secret
ENCRYPTION_KEY=64_HEX_CHARACTERS
MCP_TOKEN_ENCRYPTION_KEY=
BRUNO_ADMIN_EMAILS=
PLANEVO_OWNER_EMAILS=

# Stripe
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
SUPABASE_WEBHOOK_SECRET=

# Google Calendar
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Notion MCP OAuth
NEXT_PUBLIC_NOTION_CLIENT_ID=YOUR_NOTION_CLIENT_ID
NOTION_CLIENT_SECRET=YOUR_NOTION_CLIENT_SECRET

# Optional integrations
# Composio powers Notion, Slack, and Linear OAuth. Whitelist these callback URLs
# in the Composio dashboard (Project Settings / Auth configs):
#   http://localhost:3000/api/integrations/composio/callback
#   https://planevo.co/api/integrations/composio/callback
# Optional per-toolkit version overrides (defaults to 20260512_00)
# COMPOSIO_TOOLKIT_VERSION_NOTION=
# COMPOSIO_TOOLKIT_VERSION_SLACK=
# COMPOSIO_TOOLKIT_VERSION_LINEAR=
COMPOSIO_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM="Planevo <notifications@planevo.co>"
# Deprecated alias kept for backwards compatibility
WEEKLY_REVIEW_FROM="Planevo <notifications@planevo.co>"

# Analytics and error reporting
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Feature flags
NEXT_PUBLIC_ENABLE_HABITS=false
NEXT_PUBLIC_ENABLE_PROJECTS=false
NEXT_PUBLIC_ENABLE_FOCUS=false
NEXT_PUBLIC_ENABLE_ACADEMIC_SEARCH=false
NEXT_PUBLIC_ENABLE_GARDEN_OF_DONE=false
NEXT_PUBLIC_ENABLE_ARCHIVES=false
NEXT_PUBLIC_ENABLE_COMMAND_CENTER=false
NEXT_PUBLIC_ENABLE_OMNIBOX=false
NEXT_PUBLIC_ENABLE_N8N=false
NEXT_PUBLIC_ENABLE_NOTION=false
NEXT_PUBLIC_ENABLE_SLACK=false
NEXT_PUBLIC_ENABLE_LINEAR=false
NEXT_PUBLIC_ENABLE_AI_PRIORITIZE=false
NEXT_PUBLIC_ENABLE_AI_BREAKDOWN=false
NEXT_PUBLIC_ENABLE_AI_DECOMPOSE=false
NEXT_PUBLIC_ENABLE_AI_ARCHITECT=false
NEXT_PUBLIC_ENABLE_BRUNO_BRAIN=false
NEXT_PUBLIC_ENABLE_AI_SUGGESTIONS=false

# E2E tests
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
