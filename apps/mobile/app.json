{
  "expo": {
    "name": "Planevo",
    "owner": "planevo",
    "slug": "planevo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "planevo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9f5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.planevo.mobile",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.planevo.mobile"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f8f9f5"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.planevo.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#d4a574"
        }
      ],
      [
        "@bacons/apple-targets",
        {}
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "planevo",
          "project": "planevo-mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc8fa403-d220-496f-94ae-8228633d8a34"
      }
    }
  }
}
