{
  "expo": {
    "name": "Planevo",
    "owner": "vegad_tv",
    "slug": "planevo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "planevo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8f9f5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.planevo.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f8f9f5"
      },
      "package": "com.planevo.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#d4a574"
        }
      ],
      "expo-font",
      "./plugins/fix-jcenter"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7031fc6-98d4-425a-bba7-a0c43b9e2056"
      }
    }
  }
}
