# Required: client-safe Supabase credentials.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Required for AI/chat requests from the mobile app.
# The iOS Simulator can reach a server running on this Mac via localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Required by the current startup flow. Use RevenueCat's public iOS SDK key.
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_YOUR_PUBLIC_IOS_SDK_KEY

# Optional analytics and error reporting.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=

# Public website used for links and onboarding callbacks.
EXPO_PUBLIC_WEB_URL=https://planevo.co

# Optional: enables the iOS widget target and App Group.
# Use the 10-character Team ID from your Apple Developer account.
EXPO_APPLE_TEAM_ID=
